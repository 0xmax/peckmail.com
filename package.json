{
  "name": "perchpad",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"node --env-file=.env --import tsx src/server/index.ts\" \"node --import tsx esbuild.config.ts\" \"npx @tailwindcss/cli -i src/client/index.css -o dist/public/style.css --watch\"",
    "build": "node --import tsx esbuild.config.ts --once && npx @tailwindcss/cli -i src/client/index.css -o dist/public/style.css --minify",
    "start": "node --env-file=.env dist/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "hono": "^4.7.0",
    "isomorphic-git": "^1.27.0",
    "resend": "^6.9.1",
    "uuid": "^11.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@lezer/highlight": "^1.2.0",
    "@tailwindcss/cli": "^4.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "codemirror": "^6.0.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "marked": "^17.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
